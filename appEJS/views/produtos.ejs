<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/produtos/detalhes/0">Produtos</a>
      </nav>
    </header>

    <main>
      <h1><%= title %></h1>
      <p>Aqui você encontrará informações sobre nossos produtos. Clique em um produto para ver detalhes.</p>

      <div class="cards-container">
        <% if (produtos && produtos.length) { %>
          <% produtos.forEach(produto => { %>
            <div class="card">
              <div class="card-icon" aria-hidden="true"><%= produto.icon %></div>
              <h3><%= produto.nome %></h3>
              <p><%= produto.descricao %></p>
              <p><a href="/produtos/detalhes/<%= produto.id %>">Ver detalhes</a></p>
            </div>
          <% }); %>
        <% } else { %>
          <p>Sem produtos disponíveis.</p>
        <% } %>

        <div class="card">
          <div class="card-icon" aria-hidden="true">💡</div>
          <h3>Dicas de uso</h3>
          <p>Manutenção e segurança ao utilizar ferramentas e equipamentos.</p>
        </div>
      </div>
    </main>

    <footer class="site-footer">Produtos - catálogo</footer>
  </body>
</html>
