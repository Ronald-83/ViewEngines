<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/futebol">Futebol</a>
        <a href="/futebol/jogadores">Jogadores</a>
        <a href="/produtos/detalhes/0">Produtos</a>
      </nav>
    </header>

    <main>
      <h1><%= title %></h1>
      <p>Informações sobre o mundo do futebol.</p>

      <div class="lead">
        <p>Confira campeonatos, curiosidades e jogadores de destaque.</p>
      </div>

      <div class="cards-container">
        <% if (itens && itens.length) { %>
          <% itens.forEach(item => { %>
            <div class="card">
              <div class="card-icon" aria-hidden="true"><%= item.icon %></div>
              <h3><%= item.nome %></h3>
              <p><%= item.descricao %></p>
            </div>
          <% }); %>
        <% } else { %>
          <p>Sem itens para exibir.</p>
        <% } %>
        <div class="card">
          <div class="card-icon" aria-hidden="true">📊</div>
          <h3>Estatísticas</h3>
          <p>Gráficos e números sobre desempenho de equipes e jogadores.</p>
        </div>
      </div>
    </main>

    <footer class="site-footer">Futebol - dados dinâmicos</footer>
  </body>
</html>