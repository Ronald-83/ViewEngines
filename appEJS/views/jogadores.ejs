<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/futebol">Futebol</a>
        <a href="/futebol/jogadores">Jogadores</a>
        <a href="/produtos/detalhes/0">Produtos</a>
      </nav>
    </header>

    <main>
      <h1><%= title %></h1>
      <p>Jogadores famosos do futebol.</p>

      <div class="cards-container">
        <% if (jogadores && jogadores.length) { %>
          <% jogadores.forEach(jogador => { %>
            <div class="card">
              <div class="card-icon" aria-hidden="true"><%= jogador.icon %></div>
              <h3><%= jogador.nome %></h3>
              <p><%= jogador.descricao %></p>
            </div>
          <% }); %>
        <% } else { %>
          <p>Nenhum jogador encontrado.</p>
        <% } %>
        <div class="card">
          <div class="card-icon" aria-hidden="true">🏅</div>
          <h3>Top Recordes</h3>
          <p>Lista de recordes históricos e feitos memoráveis no esporte.</p>
        </div>
      </div>
    </main>

    <footer class="site-footer">Lista de jogadores</footer>
  </body>
</html>