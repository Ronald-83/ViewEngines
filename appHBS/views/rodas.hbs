<h1>{{title}}</h1>
<p>Tipos de rodas para bicicletas.</p>

<div class="cards-container">
  {{#if rodas}}
    {{#each rodas}}
      <div class="card">
        <div class="card-icon" aria-hidden="true">🛞</div>
        <h2>{{this.tipo}}</h2>
        <p>{{this.descricao}}</p>
      </div>
    {{/each}}
  {{else}}
    <p>Sem tipos de rodas cadastrados.</p>
  {{/if}}
</div>