<h1>{{title}}</h1>
<p>Informações sobre bicicletas.</p>

<p><a class="btn-sub" href="/bicicleta/rodas">Ver tipos de rodas</a></p>

<div class="cards-container">
  {{#if bicicletas}}
    {{#each bicicletas}}
      <div class="card">
        <div class="card-icon" aria-hidden="true">{{this.icon}}</div>
        <h2>{{this.nome}}</h2>
        <p>{{this.descricao}}</p>
      </div>
    {{/each}}
    <div class="card">
      <div class="card-icon" aria-hidden="true">🚲</div>
      <h2>Bicicleta Dobrável</h2>
      <p>Compacta e prática para transporte urbano e armazenamento.</p>
    </div>
  {{else}}
    <p>Sem bicicletas cadastradas.</p>
  {{/if}}
</div>