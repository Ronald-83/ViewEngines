<h1>{{title}}</h1>
<p>Lista detalhada das equipes de handebol.</p>

<div class="cards-container">
  {{#if equipes}}
    {{#each equipes}}
      <div class="card">
        <div class="card-icon" aria-hidden="true">🤾‍♂️</div>
        <h2>{{this.nome}}</h2>
        <p><strong>Treinador:</strong> {{this.treinador}}</p>
        <p>{{this.descricao}}</p>
      </div>
    {{/each}}
  {{else}}
    <p>Sem equipes cadastradas.</p>
  {{/if}}
</div>

<p><a href="/handebol">Voltar ao Handebol</a></p>

<p>Para contato e testes, envie um email para <a href="mailto:contato@example.com">contato@example.com</a>.</p>
