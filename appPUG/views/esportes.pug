extends layout

block content
  h1= title
  p Esta página fala sobre esportes.
  p
    a(href='/esportes/detalhes') Ver detalhes dos esportes →

  .cards-container
    if esportes
      each sp in esportes
        .card
          .card-icon(aria-hidden='true')
            if sp.icon
              = sp.icon
            else
              if sp.nome == 'Futebol'
                | ⚽
              else if sp.nome == 'Basquete'
                | 🏀
              else if sp.nome == 'Vôlei'
                | 🏐
              else
                | 🏷️
          h2= sp.nome
          if sp.destaque
            p= sp.destaque
          else if sp.descricao
            p= sp.descricao
    else
      p Sem esportes para exibir.

  if detalhes
    section.detalhes
      h2 Detalhes
      p Aqui estão informações mais completas sobre cada esporte.

  .cards-container
    .card
      .card-icon(aria-hidden='true') 🏆
      h2 Eventos
      p Calendários, resultados e análises das principais competições.
